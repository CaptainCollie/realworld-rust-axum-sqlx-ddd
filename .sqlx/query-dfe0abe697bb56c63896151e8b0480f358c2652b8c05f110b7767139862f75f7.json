{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT \n                    u.username, u.bio, u.image,\n                    COALESCE(f.follower_id IS NOT NULL, false) AS \"following!\"\n                FROM users u\n                LEFT JOIN follows f ON f.followed_id = u.id AND f.follower_id = $1\n                WHERE u.username = $2\n                ",
